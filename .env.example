# =========================================================================
# VCC-EAP ENVIRONMENT VARIABLES TEMPLATE (DO NOT EXPOSE PRODUCTION KEYS)
# Copy this file to '.env' and fill in your actual values before running.
# =========================================================================

# Database Configurations
DB_URL=jdbc:postgresql://localhost:5432/vcc_eap
DB_USERNAME=your_db_user_here
DB_PASSWORD=your_secure_password_here

# Redis Configurations
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TIMEOUT=5000ms

# Security / JWT Configurations
# Ensure this is a cryptographically strong random string (minimum 256 bits) in production!
JWT_SECRET=your_jwt_signing_key_secret_must_be_long_and_secure_here

# Storage Settings
EAP_UPLOAD_DIR=./eap-storage
